# deploy/test/fixtures/.env.bench — bench fixture for the container-compose
# regression gate (cortex#2284). PLACEHOLDER-ONLY, by rule: every value here is
# a dummy. NO real Discord snowflakes, NO real tokens, NO real slugs — ever
# (confidentiality standard: compass/standards/data-classification.md).
#
# Shapes satisfy `cortex quickstart`'s env-contract validation
# (quickstart-lib.ts): slugs/principals are lowercase letter-first, snowflakes
# are 1-20 decimal digits, secrets are presence-checked only (never echoed).

# ── Identity ────────────────────────────────────────────────────────────────
CTX_PRINCIPAL=bench-principal
CTX_SLUG=benchslug

# ── Bus ports (scaffold defaults — must match nats.conf) ────────────────────
CTX_NATS_PORT=4222
CTX_NATS_MON=8222

# ── Discord ids (numeric placeholder snowflakes) ────────────────────────────
CTX_GUILD_ID=100000000000000001
CTX_CHANNEL_ID=100000000000000002
CTX_LOG_CHANNEL_ID=100000000000000003
CTX_MY_DISCORD_ID=100000000000000004

# ── Secrets (dummy — the bench asserts boot + bus link, not surface login) ──
CTX_DISCORD_TOKEN=dummy-bench-token
CLAUDE_CODE_OAUTH_TOKEN=dummy-bench-oauth
